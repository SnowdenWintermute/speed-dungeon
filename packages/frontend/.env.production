NEXT_PUBLIC_ASSET_BASE_PATH_3D="https://roguelikeracing.com/asset/assets/"

# PROD
NEXT_PUBLIC_BASE_URL="https://roguelikeracing.com"
NEXT_PUBLIC_AUTH_SERVER_URL="https://roguelikeracing.com/auth"
# lobby REST (profiles, ladders, game records) — nginx /api -> lobby
NEXT_PUBLIC_GAME_SERVER_URL="https://roguelikeracing.com/api"
# lobby websocket on its own path — nginx /lobby -> lobby WS
NEXT_PUBLIC_WS_SERVER_URL="https://roguelikeracing.com/lobby"
# dedicated asset container route — nginx /asset -> asset server (rewritten to its internal /api)
NEXT_PUBLIC_ASSET_SERVER_URL="https://roguelikeracing.com/asset"
# wipe + re-fetch the asset cache on every load in prod. "true" to exercise the
# reconnect-with-cleared-cache path; "false" for normal operation (keep the cache across refreshes).
NEXT_PUBLIC_SHOULD_CLEAR_CACHE_IN_PRODUCTION="true"
