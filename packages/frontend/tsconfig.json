{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@speed-dungeon/*": ["../packages/*"],
      "@/client-application": ["../client-application/src/index.ts"],
      "@/client-application/*": ["../client-application/src/*"],
      "@/game-world-view": ["../game-world-view/src/index.ts"],
      "@/game-world-view/*": ["../game-world-view/src/*"],
      "@/*": ["./src/*"]
    },
    "target": "ES2017"
  },
  "references": [
    {
      "path": "../common"
    }
  ],
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
