# Copy to .env.deploy and fill in real values. .env.deploy is gitignored.
# Consumed by docker-compose.deploy.yml as env_file for every service.
# Container-network wiring (POSTGRES_HOST, VALKEY_URL, per-role name/port/urls) is set in the
# compose file's `environment:` blocks, which override anything here — keep those out of this file.

NODE_ENV=production

# --- secrets ---
# every lobby and game server container must share the SAME value. Generate with:
#   openssl rand -base64 32
TOKENS_SECRET=replace-me-openssl-rand-base64-32
# cookie shared with snowauth for internal service-to-service calls
INTERNAL_SERVICES_SECRET=replace-me

# --- postgres (creds only; host/port come from the compose environment block) ---
POSTGRES_USER=speed_dungeon
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=speed_dungeon
# host/port must match the compose postgres service and its internal port (5432)
DATABASE_URL=postgresql://speed_dungeon:replace-me@speed-dungeon-postgres:5432/speed_dungeon

# --- public edge urls ---
FRONT_END_URL=https://roguelikeracing.com
AUTH_SERVER_URL=https://roguelikeracing.com/auth
