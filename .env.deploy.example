# Template for `.speed-dungeon-env` — the env_file vps.docker.yml mounts into the speed-dungeon
# lobby, both game servers, and postgres. Copy to `.speed-dungeon-env` on the box and fill in real
# values; `.speed-dungeon-env` is gitignored (real secrets).
#
# Only vars NOT already set inline in vps.docker.yml's `environment:` blocks belong here. Those
# inline vars — POSTGRES_HOST, VALKEY_URL, LOBBY_PORT, RUN_MIGRATIONS_ON_BOOT, the GAME_SERVER_*
# set, ASSET_SERVER_URL, and the asset server's entire env — override anything here, so leave them
# out of this file.

NODE_ENV=production

# --- secrets ---
# lobby + both game servers must share the SAME value. Generate with: openssl rand -base64 32
TOKENS_SECRET=replace-me-openssl-rand-base64-32
# must be IDENTICAL to snowauth's INTERNAL_SERVICES_SECRET (snowauth's .env) for internal calls
INTERNAL_SERVICES_SECRET=replace-me

# --- postgres (creds for the speed-dungeon-postgres container; the app connects via DATABASE_URL) ---
POSTGRES_USER=speed_dungeon
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=speed_dungeon
# host must be the compose service name speed-dungeon-postgres on its internal port 5432
DATABASE_URL=postgresql://speed_dungeon:replace-me@speed-dungeon-postgres:5432/speed_dungeon

# --- edge / service urls ---
FRONT_END_URL=https://roguelikeracing.com
# the lobby calls ${AUTH_SERVER_URL}/internal/sessions; snowauth lives in the same compose project,
# so use its internal container url and keep the /auth prefix snowauth serves its routes under
AUTH_SERVER_URL=http://snowauth-server:8081/auth
